---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <p class="copyright">
      &copy; {year} Personal Tech Blog. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--bg-secondary);
    border-top: 1px solid var(--border);
    padding: var(--space-6);
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .copyright {
    color: var(--text-secondary);
    font-size: 0.875rem;
    margin: 0;
  }
</style>
