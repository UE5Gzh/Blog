---
const { title } = Astro.props;
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="logo">{title || 'Tech Blog'}</a>
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background-color: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
    padding: var(--space-4) var(--space-6);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .logo:hover {
    color: var(--accent);
  }

  .nav {
    display: flex;
    gap: var(--space-4);
  }

  .nav a {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .nav a:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .header {
      padding: var(--space-3) var(--space-4);
    }

    .header-inner {
      flex-direction: column;
      gap: var(--space-3);
    }

    .nav {
      gap: var(--space-3);
    }
  }
</style>
