---
// Search component using Pagefind
// Pagefind is a static search library that indexes the built site
---

<div id="search" class="search-container"></div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

<script is:inline>
  // Load Pagefind UI when available
  function initSearch() {
    // Check if Pagefind is available (only after build)
    if (typeof window.pagefind === 'undefined') {
      // Pagefind not available in dev mode, show message
      const searchContainer = document.getElementById('search');
      if (searchContainer) {
        searchContainer.innerHTML = `
          <div class="search-placeholder">
            <p>Search is available after running <code>npm run build</code></p>
          </div>
        `;
      }
      return;
    }

    // Initialize Pagefind UI
    window.pagefind.init().then(() => {
      const searchContainer = document.getElementById('search');
      if (searchContainer) {
        const search = new window.pagefind.ui({
          element: '#search',
          showImages: false,
          resetStyles: false
        });
      }
    }).catch(err => {
      console.error('Pagefind initialization failed:', err);
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearch);
  } else {
    initSearch();
  }
</script>

<style>
  .search-container {
    margin: 1.5rem 0;
  }

  .search-placeholder {
    padding: 1rem;
    background: var(--surface-secondary, #f5f5f5);
    border-radius: 8px;
    text-align: center;
    color: var(--text-secondary);
  }

  .search-placeholder code {
    background: var(--border, #e5e5e5);
    padding: 0.125rem 0.25rem;
    border-radius: 4px;
    font-size: 0.875rem;
  }

  /* Pagefind UI styles override */
  :global(.pagefind-ui__search-input) {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 1px solid var(--border, #e5e5e5);
    border-radius: 8px;
    background: var(--background, #ffffff);
    color: var(--text-primary);
  }

  :global(.pagefind-ui__result) {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border, #e5e5e5);
  }

  :global(.pagefind-ui__result-title) {
    font-weight: 600;
    color: var(--text-primary);
  }

  :global(.pagefind-ui__result-excerpt) {
    color: var(--text-secondary);
    margin-top: 0.25rem;
  }
</style>