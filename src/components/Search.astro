---
// Pagefind UI wrapper component
// Pagefind is a static search library that indexes the built HTML
// Usage: <Search /> renders the Pagefind search UI
// Note: Pagefind only works after build (npm run build), not in dev mode
---

<div id="search" class="search-container"></div>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

<script>
  // @ts-ignore - Pagefind is injected at build time
  import PagefindUI from '/pagefind/pagefind-ui.js';

  window.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      resetStyles: false,
    });
  });
</script>

<style>
  .search-container {
    margin-bottom: var(--space-6);
  }

  /* Override Pagefind styles to match theme */
  :global(.pagefind-ui__search-input) {
    background: var(--bg-secondary) !important;
    border: 1px solid var(--border) !important;
    color: var(--text-primary) !important;
    border-radius: var(--radius-md) !important;
    padding: var(--space-3) var(--space-4) !important;
  }

  :global(.pagefind-ui__result) {
    background: var(--bg-secondary) !important;
    border: 1px solid var(--border) !important;
    border-radius: var(--radius-md) !important;
    margin-bottom: var(--space-3) !important;
    padding: var(--space-4) !important;
  }

  :global(.pagefind-ui__result-title) {
    color: var(--accent) !important;
  }

  :global(.pagefind-ui__result-excerpt) {
    color: var(--text-secondary) !important;
  }

  :global(.pagefind-ui__search-clear) {
    color: var(--text-secondary) !important;
  }
</style>