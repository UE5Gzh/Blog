<div id="search" class="search-container"></div>

<script is:inline>
  // Load Pagefind UI after page load - only when running in browser after build
  (function() {
    function initPagefind() {
      // Check if pagefind is available (generated at build time)
      if (document.querySelector('#search') && window.PagefindUI) {
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          resetStyles: false,
        });
      }
    }

    // Load pagefind script if it exists
    if (document.querySelector('#search')) {
      var script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = initPagefind;
      script.onerror = function() {
        // Pagefind not available (dev mode) - silently skip
      };
      document.head.appendChild(script);

      // Also load CSS
      var link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);
    }
  })();
</script>

<style>
  .search-container {
    margin-bottom: var(--space-6);
  }

  /* Override Pagefind styles to match theme */
  :global(.pagefind-ui__search-input) {
    background: var(--bg-secondary) !important;
    border: 1px solid var(--border) !important;
    color: var(--text-primary) !important;
    border-radius: var(--radius-md) !important;
    padding: var(--space-3) var(--space-4) !important;
  }

  :global(.pagefind-ui__result) {
    background: var(--bg-secondary) !important;
    border: 1px solid var(--border) !important;
    border-radius: var(--radius-md) !important;
    margin-bottom: var(--space-3) !important;
    padding: var(--space-4) !important;
  }

  :global(.pagefind-ui__result-title) {
    color: var(--accent) !important;
  }

  :global(.pagefind-ui__result-excerpt) {
    color: var(--text-secondary) !important;
  }

  :global(.pagefind-ui__search-clear) {
    color: var(--text-secondary) !important;
  }
</style>
