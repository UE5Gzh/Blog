---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const archive = posts.reduce((acc, post) => {
  const year = post.data.date.getFullYear();
  const month = post.data.date.getMonth();

  if (!acc[year]) {
    acc[year] = {};
  }
  if (!acc[year][month]) {
    acc[year][month] = [];
  }
  acc[year][month].push(post);

  return acc;
}, {});

const years = Object.keys(archive).sort((a, b) => Number(b) - Number(a));
const latestYear = years[0];

function getYearPostCount(year: number | string) {
  return Object.values(archive[year]).reduce((sum, monthPosts) => sum + monthPosts.length, 0);
}
---

<BaseLayout title="Archive" description="Archive of all blog posts by date">
  <section class="archive-header">
    <h1>Archive</h1>
    <p class="post-count">{posts.length} {posts.length === 1 ? 'post' : 'posts'} total</p>
  </section>

  <section class="archive-content">
    {years.map((year) => {
      const isLatestYear = year === latestYear;
      const yearPostCount = getYearPostCount(year);
      
      return (
        <div class="year-section" data-year={year} class:list={[{ collapsed: !isLatestYear }]}>
          <button class="year-toggle" aria-expanded={isLatestYear}>
            <svg class="chevron-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
            <span class="year-title">{year}</span>
            <span class="year-post-count">{yearPostCount}</span>
          </button>
          <div class="year-content">
            {Object.keys(archive[year])
              .sort((a, b) => Number(b) - Number(a))
              .map(month => (
                <div class="month-section">
                  <h3 class="month-title">
                    {new Date(Number(year), Number(month), 1).toLocaleDateString('en-US', { month: 'long' })}
                  </h3>
                  <ul class="post-list">
                    {archive[year][Number(month)].map(post => (
                      <li>
                        <a href={`/posts/${post.slug}`} class="post-link">
                          <span class="post-title">{post.data.title}</span>
                          <span class="post-date">
                            {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                          </span>
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
          </div>
        </div>
      );
    })}
  </section>
</BaseLayout>

<script>
  function initArchiveToggle() {
    document.querySelectorAll('.year-toggle').forEach(toggle => {
      toggle.addEventListener('click', () => {
        const section = toggle.closest('.year-section');
        if (!section) return;
        
        const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!isExpanded));
        section.classList.toggle('collapsed');
      });
    });
  }

  initArchiveToggle();
  document.addEventListener('astro:page-load', initArchiveToggle);
</script>

<style>
  .archive-header {
    text-align: center;
    padding: var(--space-8) 0;
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--border);
  }

  .archive-header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-3);
  }

  .post-count {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .year-section {
    margin-bottom: var(--space-4);
    border-radius: 12px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .year-section:hover {
    border-color: rgba(88, 166, 255, 0.3);
  }

  .year-toggle {
    width: 100%;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-6);
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.2s ease;
  }

  .year-toggle:hover {
    background: rgba(88, 166, 255, 0.05);
  }

  .chevron-icon {
    color: var(--accent);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .year-section.collapsed .chevron-icon {
    transform: rotate(-90deg);
  }

  .year-title {
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .year-post-count {
    font-size: 0.8rem;
    color: var(--text-secondary);
    background: var(--bg-primary);
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    margin-left: auto;
  }

  .year-content {
    padding: 0 var(--space-6) var(--space-5);
    max-height: 3000px;
    opacity: 1;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), 
                padding 0.3s ease, 
                opacity 0.25s ease;
  }

  .year-section.collapsed .year-content {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    opacity: 0;
    overflow: hidden;
  }

  .month-section {
    margin-bottom: var(--space-5);
  }

  .month-section:last-child {
    margin-bottom: 0;
  }

  .month-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--border);
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-list li {
    margin-bottom: 2px;
  }

  .post-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-3) var(--space-4);
    color: var(--text-primary);
    text-decoration: none;
    border-radius: 8px;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .post-link:hover {
    background: rgba(88, 166, 255, 0.08);
    color: var(--accent);
  }

  .post-title {
    font-size: 0.95rem;
    line-height: 1.4;
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--text-secondary);
    flex-shrink: 0;
    margin-left: var(--space-4);
  }

  @media (max-width: 640px) {
    .year-toggle {
      padding: var(--space-4) var(--space-4);
    }

    .year-title {
      font-size: 1.2rem;
    }

    .year-content {
      padding: 0 var(--space-4) var(--space-4);
    }

    .post-link {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-1);
    }

    .post-date {
      margin-left: 0;
    }
  }
</style>
