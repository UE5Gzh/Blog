---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

// Get all posts
const allPosts = await getCollection('posts', ({ data }) => !data.draft);

// Extract unique categories
const categories = [...new Set(allPosts.map(post => post.data.category).filter(Boolean))];

// Create paths for each category
export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const categories = [...new Set(allPosts.map(post => post.data.category).filter(Boolean))];

  return categories.map(category => {
    const filteredPosts = allPosts
      .filter(post => post.data.category === category)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

    return {
      params: { category },
      props: { posts: filteredPosts, category },
    };
  });
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`Category: ${category}`} description={`Posts in category: ${category}`}>
  <section class="category-header">
    <h1>Category: {category}</h1>
    <p class="post-count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
  </section>

  <section class="posts-section">
    {posts.length > 0 ? (
      <div class="post-grid">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>No posts in this category</h2>
        <p>Check back soon for new content!</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .category-header {
    text-align: center;
    padding: var(--space-8) 0;
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--border);
  }

  .category-header h1 {
    font-size: 2rem;
    margin-bottom: var(--space-4);
  }

  .post-count {
    color: var(--text-secondary);
    font-size: 1rem;
  }

  .posts-section h2 {
    margin-bottom: var(--space-6);
  }
</style>
