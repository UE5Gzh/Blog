---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

// Get all posts
const allPosts = await getCollection('posts');

// Filter to only published posts (draft: false)
const posts = allPosts.filter(post => !post.data.draft);

// Sort by date descending (newest first)
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Home" description="A personal technical blog for sharing programming tutorials and insights">
  <section class="hero">
    <h1>Welcome to My Tech Blog</h1>
    <p class="subtitle">Sharing programming tutorials, insights, and developer experiences</p>
  </section>

  <section class="posts-section">
    <h2>Latest Posts</h2>
    {posts.length > 0 ? (
      <div class="post-grid">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h2>No posts yet</h2>
        <p>Check back soon for new content!</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: var(--space-8) 0;
    margin-bottom: var(--space-8);
    border-bottom: 1px solid var(--border);
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .posts-section h2 {
    margin-bottom: var(--space-6);
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 1.75rem;
    }

    .subtitle {
      font-size: 1rem;
    }
  }
</style>
